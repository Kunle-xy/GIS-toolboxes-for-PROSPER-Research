# NEW, Gaussian filter for arrays with NaN, keeps nodata masked and avoids value bleeding
from scipy.ndimage import gaussian_filter

def _gaussian_filter_nan(arr, sigma):
    """
    Apply Gaussian smoothing to an array that may contain NaN.
    Normalizes by a binary mask so NaN regions remain NaN.
    """
    if sigma is None or sigma <= 0:
        return arr
    a = arr.astype(float).copy()
    nan_mask = np.isnan(a)
    a[nan_mask] = 0.0
    w = (~nan_mask).astype(float)

    a_blur = gaussian_filter(a, sigma=sigma, mode="nearest")
    w_blur = gaussian_filter(w, sigma=sigma, mode="nearest")

    with np.errstate(invalid="ignore", divide="ignore"):
        out = a_blur / w_blur
    out[w_blur == 0] = np.nan
    return out

def hex_to_rgba(hex_color, alpha):
    """Convert a hex color like #1f77b4 to rgba string with given alpha."""
    h = hex_color.lstrip('#')
    r = int(h[0:2], 16)
    g = int(h[2:4], 16)
    b = int(h[4:6], 16)
    return f"rgba({r},{g},{b},{alpha})"

